{
  "name": "sysml-v2-studio",
  "displayName": "SysML v2 Studio",
  "description": "SysML v2 (.sysml / .kerml) authoring, visualization, and editing: language support, 8 editable diagram kinds, Claude (MCP) integration",
  "version": "0.8.2",
  "publisher": "engineer-fumi",
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#14141f",
    "theme": "dark"
  },
  "pricing": "Free",
  "repository": {
    "type": "git",
    "url": "https://github.com/engineer-fumi/sysml-v2-studio"
  },
  "homepage": "https://github.com/engineer-fumi/sysml-v2-studio#readme",
  "bugs": {
    "url": "https://github.com/engineer-fumi/sysml-v2-studio/issues"
  },
  "qna": false,
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "keywords": [
    "sysml",
    "sysml-v2",
    "kerml",
    "mbse",
    "modeling"
  ],
  "main": "./dist/extension.js",
  "bin": {
    "sysml-v2-mcp": "./dist/mcp.cjs"
  },
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "sysml-v2-studio.mcp",
        "label": "SysML v2 Studio"
      }
    ],
    "languages": [
      {
        "id": "sysml",
        "aliases": [
          "SysML v2",
          "sysml"
        ],
        "extensions": [
          ".sysml",
          ".kerml"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sysml",
        "scopeName": "source.sysml",
        "path": "./syntaxes/sysml.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "sysml.openDiagram",
        "title": "SysML: Open Diagram",
        "icon": "$(type-hierarchy-sub)"
      },
      {
        "command": "sysml.openDiagramAs",
        "title": "SysML: Open Diagram by Kind",
        "icon": "$(type-hierarchy)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "sysml.openDiagram",
          "when": "editorLangId == sysml",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "sysml.openDiagram"
        },
        {
          "command": "sysml.openDiagramAs"
        }
      ]
    },
    "configuration": {
      "title": "SysML v2 Studio",
      "properties": {
        "sysml.validation.unresolvedReferences": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "information",
            "off"
          ],
          "default": "warning",
          "description": "Diagnostic level for unresolved references (types, specializations, connection targets, etc.)"
        },
        "sysml.validation.duplicateNames": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "information",
            "off"
          ],
          "default": "error",
          "description": "Diagnostic level for duplicate names in the same scope"
        },
        "sysml.validation.typeConformance": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "information",
            "off"
          ],
          "default": "warning",
          "description": "Diagnostic level for typing and specialization kind conformance (e.g. part must be typed by part def)"
        },
        "sysml.validation.shadowing": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "information",
            "off"
          ],
          "default": "warning",
          "description": "Diagnostic level when an inherited member is hidden by a same-named declaration (redefine with :>> is recommended)"
        },
        "sysml.validation.importVisibility": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "information",
            "off"
          ],
          "default": "warning",
          "description": "Diagnostic level when the visibility (public/private) of an import is not explicitly specified"
        },
        "sysml.validation.typeChecking": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "information",
            "off"
          ],
          "default": "warning",
          "description": "The diagnostic level for type checking of an expression (e.g., constraint body is Boolean, value conforms to declared type, etc.). Only reports if the type is definitively determined."
        }
      }
    }
  },
  "scripts": {
    "check": "tsc -p tsconfig.extension.json --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "build": "npm run check && node esbuild.mjs",
    "build:mcp": "esbuild src/mcp/server.ts --bundle --platform=node --format=cjs --banner:js=\"#!/usr/bin/env node\" --outfile=dist/mcp.cjs --log-level=error",
    "build:mcp:pkg": "npm run build:mcp && node scripts/build-mcp-package.mjs",
    "test:mcp": "esbuild test/mcp.ts --bundle --platform=node --outfile=dist/mcp-test.cjs --log-level=error && node dist/mcp-test.cjs",
    "smoke:mcp": "npm run build:mcp:pkg && node scripts/smoke-mcp.mjs",
    "publish:mcp": "npm run build:mcp:pkg && node scripts/smoke-mcp.mjs && npm publish ./dist/npm --access public",
    "watch": "node esbuild.mjs --watch",
    "test:core": "esbuild test/core.ts --bundle --platform=node --outfile=dist/core-test.cjs --log-level=error && node dist/core-test.cjs",
    "test:geometry": "esbuild test/geometry.ts --bundle --platform=node --outfile=dist/geometry-test.cjs --log-level=error && node dist/geometry-test.cjs",
    "test:parser": "esbuild test/parser.ts --bundle --platform=node --outfile=dist/parser-test.cjs --log-level=error && node dist/parser-test.cjs",
    "test:hooks": "esbuild test/hooks.ts --bundle --platform=node --packages=external --format=cjs --outfile=dist/hooks-test.cjs --log-level=error && node dist/hooks-test.cjs",
    "test:fuzz": "esbuild test/fuzz.ts --bundle --platform=node --outfile=dist/fuzz-test.cjs --log-level=error && node dist/fuzz-test.cjs",
    "test:e2e": "node esbuild.mjs && esbuild test/e2e/genModel.ts --bundle --platform=node --outfile=dist/e2e-genmodel.cjs --log-level=error && node dist/e2e-genmodel.cjs && playwright test",
    "test:ui": "node esbuild.mjs && extest setup-and-run './test/ui/*.test.js' --extensions_dir .test-extensions -o ./test/ui/settings.json",
    "gen:screenshots": "node esbuild.mjs && esbuild scripts/gen-demo-model.ts --bundle --platform=node --outfile=dist/gen-demo-model.cjs --log-level=error && node dist/gen-demo-model.cjs && node scripts/gen-screenshots.mjs",
    "test:unit": "npm run test:core && npm run test:geometry && npm run test:parser && npm run test:hooks && npm run test:fuzz && npm run test:mcp",
    "corpus:clone": "node scripts/clone-corpus.mjs",
    "coverage:grammar": "esbuild scripts/grammar-coverage.ts --bundle --platform=node --outfile=dist/grammar-coverage.cjs --log-level=error && node dist/grammar-coverage.cjs",
    "gen:icon": "node scripts/gen-icon.mjs",
    "test:vscode": "node test/runTest.mjs",
    "package": "npm run build && npm run build:mcp && vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20.17.30",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.7",
    "@types/vscode": "^1.101.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.3.2",
    "esbuild": "^0.25.4",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.8.3",
    "vscode-extension-tester": "^8.23.0"
  }
}
